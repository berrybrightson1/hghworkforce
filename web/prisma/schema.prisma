// HGH Payroll — PostgreSQL on Supabase (pooled DATABASE_URL + DIRECT_URL for migrations)
// See: https://supabase.com/docs/guides/database/connecting-to-postgres
//
// DATABASE_URL (Transaction pooler / port 6543) MUST include ?pgbouncer=true (or &pgbouncer=true).
// Without it, Postgres can error: 42P05 "prepared statement \"sN\" already exists" on Vercel/PgBouncer.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  HR
  EMPLOYEE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACTOR
}

enum EmployeeStatus {
  ACTIVE
  SUSPENDED
  TERMINATED
}

enum SalaryComponentType {
  ALLOWANCE
  DEDUCTION
}

enum PayrunStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum LeaveType {
  ANNUAL
  SICK
  MATERNITY
  PATERNITY
  COMPASSIONATE
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LoanType {
  LOAN
  ADVANCE
}

enum LoanStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum SubscriptionStatus {
  NONE
  ACTIVE
  TRIAL
  PAST_DUE
  CANCELED
}

model Company {
  id                 String             @id @default(cuid())
  name               String
  logoUrl            String?
  registrationNumber String?
  address            String?
  isActive           Boolean            @default(true)
  /// ACTIVE = paid subscriber (full access). Other values: access until trialEndsAt (or createdAt + trial window if trialEndsAt is null).
  subscriptionStatus SubscriptionStatus @default(NONE)
  /// End of the free trial (all features). If null, the app treats the trial end as createdAt + 3 days (see TRIAL_DAYS in billing/access.ts).
  trialEndsAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  users             User[]
  employees         Employee[]
  payruns           Payrun[]
  taxBrackets       TaxBracket[]
  leaveEntitlements LeaveEntitlement[]
  invitations       Invitation[]

  /// Enterprise check-in (IP allowlist, audit sessions, optional face match)
  checkinEnterpriseEnabled       Boolean  @default(false)
  checkinEnforceIpAllowlist      Boolean  @default(false)
  /// When true, the first successful visit to employee check-in from a browser saves that public IP; only that IP can load check-in or POST check-ins until cleared in settings.
  checkinLockToFirstIp           Boolean  @default(true)
  /// Normalized IPv4/IPv6 captured on first check-in page load (see checkinLockToFirstIp).
  checkinBoundIp                 String?
  checkinRequireFaceVerification Boolean  @default(false)
  /// L2 distance threshold for face descriptor match (default applied in app if null)
  checkinFaceDistanceThreshold   Decimal? @db.Decimal(8, 5)
  checkinMaxFaceAttempts         Int      @default(3)

  /// Office kiosk: local HH:mm in kioskTimezone (null = no open/close restriction)
  kioskOfficeOpensAt     String?
  kioskOfficeClosesAt    String?
  /// After this local time, new clock-in blocked; cron marks absent (shift employees)
  kioskCutoffTime        String?
  /// IANA timezone e.g. Africa/Accra
  kioskTimezone          String  @default("Africa/Accra")
  /// Local YYYY-MM-DD when kiosk absence cron last ran (idempotency)
  kioskLastAbsentRunDate String?

  /// Ghana Tier 2 occupational pension (optional); % of basic salary — employee deduction + employer cost on pay run lines
  tier2PensionEnabled  Boolean @default(false)
  tier2EmployeePercent Decimal @default(5) @db.Decimal(5, 2)
  tier2EmployerPercent Decimal @default(5) @db.Decimal(5, 2)

  allowedIps            AllowedIP[]
  kioskDayAbsences      KioskDayAbsence[]
  ipAccessRequests      IPAccessRequest[]
  checkinSessions       CheckinSession[]
  faceMismatchAlerts    FaceMismatchAlert[]
  webhooks              CompanyWebhook[]
  attendanceCorrections AttendanceCorrectionRequest[]

  @@index([isActive])
}

model User {
  id         String   @id @default(cuid())
  /// Supabase Auth user id (`auth.users.id`)
  authUserId String   @unique
  email      String   @unique
  name       String
  role       UserRole
  isActive   Boolean  @default(true)
  companyId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company                        Company?                      @relation(fields: [companyId], references: [id])
  employee                       Employee?
  auditLogs                      AuditLog[]
  invitations                    Invitation[]
  ipAccessRequestsRequested      IPAccessRequest[]             @relation("IpAccessRequestedBy")
  ipAccessRequestsReviewed       IPAccessRequest[]             @relation("IpAccessReviewedBy")
  resolvedFaceMismatchAlerts     FaceMismatchAlert[]           @relation("FaceMismatchResolvedBy")
  allowedIpsCreated              AllowedIP[]                   @relation("AllowedIpCreatedBy")
  attendanceCorrectionsRequested AttendanceCorrectionRequest[] @relation("CorrectionRequestedBy")
  attendanceCorrectionsReviewed  AttendanceCorrectionRequest[] @relation("CorrectionReviewedBy")

  @@index([authUserId])
  @@index([companyId, role])
}

model Employee {
  id                   String         @id @default(cuid())
  employeeCode         String         @unique
  /// Display name on the HR record (independent of linked User.name when invited)
  name                 String?
  userId               String?        @unique
  companyId            String
  department           String
  jobTitle             String
  employmentType       EmploymentType @default(FULL_TIME)
  startDate            DateTime
  status               EmployeeStatus @default(ACTIVE)
  basicSalary          Decimal        @db.Decimal(12, 2)
  ssnitEncrypted       String?
  tinEncrypted         String?
  bankNameEncrypted    String?
  bankAccountEncrypted String?
  bankBranchEncrypted  String?
  nokName              String?
  nokPhone             String?
  nokRelationship      String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  deletedAt            DateTime?

  /// Face-api-style embedding (JSON number[]). Null until enrolled.
  faceDescriptor   Json?
  faceRegisteredAt DateTime?

  company                      Company                       @relation(fields: [companyId], references: [id])
  user                         User?                         @relation(fields: [userId], references: [id])
  salaryComponents             SalaryComponent[]
  payrunLines                  PayrunLine[]
  payslips                     Payslip[]
  leaveRequests                LeaveRequest[]
  loans                        Loan[]
  checkIns                     CheckIn[]
  shiftAssignments             ShiftAssignment[]
  documents                    EmployeeDocument[]
  checkinSessions              CheckinSession[]
  faceMismatchAlerts           FaceMismatchAlert[]
  kioskDayAbsences             KioskDayAbsence[]
  onboardingTasks              EmployeeOnboardingTask[]
  attendanceCorrectionRequests AttendanceCorrectionRequest[]
  employeeOnboardings          EmployeeOnboarding[]
  performanceReviews           PerformanceReview[]
  exitRecords                  ExitRecord[]

  @@index([companyId, status])
  @@index([employeeCode])
}

model EmployeeDocument {
  id         String   @id @default(cuid())
  employeeId String
  name       String
  fileUrl    String
  fileType   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
}

model SalaryComponent {
  id          String              @id @default(cuid())
  employeeId  String
  type        SalaryComponentType
  name        String
  amount      Decimal             @db.Decimal(12, 2)
  isRecurring Boolean             @default(true)
  startDate   DateTime            @default(now())
  endDate     DateTime?
  note        String?
  createdAt   DateTime            @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId, type])
}

model Payrun {
  id               String       @id @default(cuid())
  companyId        String
  periodStart      DateTime
  periodEnd        DateTime
  status           PayrunStatus @default(DRAFT)
  note             String?
  createdById      String
  submittedById    String?
  approvedById     String?
  rejectedById     String?
  rejectionNote    String?
  approvalNote     String?
  approvedAt       DateTime?
  lockedAt         DateTime?
  /// Payment tracking (Section 6)
  isPaid           Boolean      @default(false)
  paidAt           DateTime?
  scheduledPayDate DateTime?
  markedPaidBy     String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  company Company      @relation(fields: [companyId], references: [id])
  lines   PayrunLine[]

  @@index([companyId, status])
  @@index([periodStart, periodEnd])
}

model PayrunLine {
  id              String  @id @default(cuid())
  payrunId        String
  employeeId      String
  grossPay        Decimal @db.Decimal(12, 2)
  ssnitEmployee   Decimal @db.Decimal(12, 2)
  ssnitEmployer   Decimal @db.Decimal(12, 2)
  taxablePay      Decimal @db.Decimal(12, 2)
  payeTax         Decimal @db.Decimal(12, 2)
  provident       Decimal @default(0) @db.Decimal(12, 2)
  loanDeductions  Decimal @default(0) @db.Decimal(12, 2)
  otherDeductions Decimal @default(0) @db.Decimal(12, 2)
  tier2Employee   Decimal @default(0) @db.Decimal(12, 2)
  tier2Employer   Decimal @default(0) @db.Decimal(12, 2)
  totalDeductions Decimal @db.Decimal(12, 2)
  netPay          Decimal @db.Decimal(12, 2)
  isOverridden    Boolean @default(false)
  overrideNote    String?
  salarySnapshot  Json

  payrun   Payrun   @relation(fields: [payrunId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])
  payslip  Payslip?

  @@unique([payrunId, employeeId])
  @@index([payrunId])
}

model Payslip {
  id            String    @id @default(cuid())
  payrunLineId  String    @unique
  employeeId    String
  pdfUrl        String
  emailedAt     DateTime?
  downloadCount Int       @default(0)
  createdAt     DateTime  @default(now())

  payrunLine PayrunLine @relation(fields: [payrunLineId], references: [id])
  employee   Employee   @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
}

model LeaveEntitlement {
  id                 String    @id @default(cuid())
  companyId          String
  leaveType          LeaveType
  /// Base annual (or period) entitlement in days
  days               Int
  isActive           Boolean   @default(true)
  /// Optional: extra days accrued per calendar month employed (from startDate), added to entitled cap
  monthlyAccrualRate Decimal?  @db.Decimal(5, 2)
  /// Optional: ceiling on total entitled (base + accrual); null = no cap
  maxBalanceDays     Int?

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, leaveType])
}

model LeaveRequest {
  id            String      @id @default(cuid())
  employeeId    String
  type          LeaveType
  startDate     DateTime
  endDate       DateTime
  days          Int
  status        LeaveStatus @default(PENDING)
  note          String?
  approvedById  String?
  approvedAt    DateTime?
  rejectionNote String?
  approvalNote  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId, status])
  @@index([startDate, endDate])
}

model Loan {
  id               String     @id @default(cuid())
  employeeId       String
  type             LoanType
  amount           Decimal    @db.Decimal(12, 2)
  balance          Decimal    @db.Decimal(12, 2)
  monthlyRepayment Decimal    @db.Decimal(12, 2)
  disbursedAt      DateTime
  status           LoanStatus @default(ACTIVE)
  note             String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId, status])
}

model TaxBracket {
  id        String   @id @default(cuid())
  companyId String?
  year      Int
  minAmount Decimal  @db.Decimal(12, 2)
  maxAmount Decimal? @db.Decimal(12, 2)
  rate      Decimal  @db.Decimal(5, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id])

  @@index([year, isActive])
}

// ─── Check-in & Shift Enums ─────────────────────────────────────────────────

enum CheckInStatus {
  CLOCKED_IN
  CLOCKED_OUT
}

enum CheckinSessionEventType {
  PORTAL_OPENED
  FACE_SCAN_STARTED
  FACE_MATCH_OK
  FACE_MATCH_FAIL
  CLOCK_IN
  CLOCK_OUT
  SESSION_INTERRUPTED
  TAB_HIDDEN
  TAB_VISIBLE
}

enum IPAccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ShiftStatus {
  ACTIVE
  INACTIVE
}

// ─── Check-in & Shift Models ────────────────────────────────────────────────

model CheckIn {
  id                 String        @id @default(cuid())
  employeeId         String
  companyId          String
  clockIn            DateTime      @default(now())
  clockOut           DateTime?
  status             CheckInStatus @default(CLOCKED_IN)
  /// Total hours worked (computed on clock-out)
  hoursWorked        Decimal?      @db.Decimal(6, 2)
  /// Overtime hours beyond scheduled shift (computed on clock-out)
  overtimeHours      Decimal?      @db.Decimal(6, 2)
  /// Minutes late relative to shift start
  lateMinutes        Int?
  /// Minutes early departure relative to shift end
  earlyDepartMinutes Int?
  note               String?
  /// If linked to a shift assignment
  shiftAssignmentId  String?
  /// Enterprise check-in session (audit trail)
  checkinSessionId   String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  employee           Employee                      @relation(fields: [employeeId], references: [id])
  shiftAssignment    ShiftAssignment?              @relation(fields: [shiftAssignmentId], references: [id])
  checkinSession     CheckinSession?               @relation(fields: [checkinSessionId], references: [id])
  correctionRequests AttendanceCorrectionRequest[]

  @@index([employeeId, clockIn])
  @@index([companyId, clockIn])
  @@index([companyId, status])
  @@index([checkinSessionId])
}

model AllowedIP {
  id          String   @id @default(cuid())
  companyId   String
  label       String?
  /// IPv4/IPv6 literal (exact match against normalized client IP)
  address     String
  createdById String?
  createdAt   DateTime @default(now())

  company   Company @relation(fields: [companyId], references: [id])
  createdBy User?   @relation("AllowedIpCreatedBy", fields: [createdById], references: [id])

  @@index([companyId])
}

model IPAccessRequest {
  id                String                @id @default(cuid())
  companyId         String
  requestedByUserId String
  requestedIp       String
  note              String?
  status            IPAccessRequestStatus @default(PENDING)
  reviewedById      String?
  reviewedAt        DateTime?
  createdAt         DateTime              @default(now())

  company     Company @relation(fields: [companyId], references: [id])
  requestedBy User    @relation("IpAccessRequestedBy", fields: [requestedByUserId], references: [id])
  reviewedBy  User?   @relation("IpAccessReviewedBy", fields: [reviewedById], references: [id])

  @@index([companyId, status])
}

model CheckinSession {
  id            String    @id @default(cuid())
  employeeId    String
  companyId     String
  clientIp      String?
  userAgent     String?
  faceFailCount Int       @default(0)
  endedAt       DateTime?
  createdAt     DateTime  @default(now())

  employee           Employee            @relation(fields: [employeeId], references: [id])
  company            Company             @relation(fields: [companyId], references: [id])
  events             CheckinEvent[]
  checkIns           CheckIn[]
  faceMismatchAlerts FaceMismatchAlert[]

  @@index([employeeId, createdAt])
  @@index([companyId, createdAt])
}

model CheckinEvent {
  id        String                  @id @default(cuid())
  sessionId String
  type      CheckinSessionEventType
  metadata  Json?
  createdAt DateTime                @default(now())

  session CheckinSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model FaceMismatchAlert {
  id               String    @id @default(cuid())
  employeeId       String
  companyId        String
  checkinSessionId String?
  metadata         Json?
  resolvedAt       DateTime?
  resolvedById     String?
  createdAt        DateTime  @default(now())

  employee   Employee        @relation(fields: [employeeId], references: [id])
  company    Company         @relation(fields: [companyId], references: [id])
  session    CheckinSession? @relation(fields: [checkinSessionId], references: [id])
  resolvedBy User?           @relation("FaceMismatchResolvedBy", fields: [resolvedById], references: [id])

  @@index([companyId, resolvedAt])
  @@index([employeeId])
}

/// Local calendar day in company kioskTimezone; absence if no check-in by cutoff.
model KioskDayAbsence {
  id         String   @id @default(cuid())
  companyId  String
  employeeId String
  /// Local date YYYY-MM-DD for company timezone
  localDate  String
  reason     String   @default("MISSING_CHECKIN")
  createdAt  DateTime @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([companyId, employeeId, localDate])
  @@index([companyId, localDate])
}

model Shift {
  id           String      @id @default(cuid())
  companyId    String
  name         String /// e.g. "Morning", "Afternoon", "Night"
  startTime    String /// HH:mm format, e.g. "08:00"
  endTime      String /// HH:mm format, e.g. "17:00"
  breakMinutes Int         @default(60)
  status       ShiftStatus @default(ACTIVE)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  assignments ShiftAssignment[]

  @@index([companyId, status])
}

model ShiftAssignment {
  id         String    @id @default(cuid())
  shiftId    String
  employeeId String
  /// Effective date range for this assignment
  startDate  DateTime
  endDate    DateTime?
  createdAt  DateTime  @default(now())

  shift    Shift     @relation(fields: [shiftId], references: [id])
  employee Employee  @relation(fields: [employeeId], references: [id])
  checkIns CheckIn[]

  @@index([employeeId, startDate])
  @@index([shiftId])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

model Invitation {
  id        String           @id @default(cuid())
  email     String
  role      UserRole
  companyId String
  code      String           @unique
  status    InvitationStatus @default(PENDING)
  invitedBy String
  expiresAt DateTime
  createdAt DateTime         @default(now())

  company Company @relation(fields: [companyId], references: [id])
  inviter User    @relation(fields: [invitedBy], references: [id])

  @@index([email, status])
  @@index([code])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String
  action      String
  entityType  String
  entityId    String
  beforeState Json?
  afterState  Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

enum AttendanceCorrectionStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Outbound integration (e.g. Zapier / internal tools) — fired when a pay run is approved
model CompanyWebhook {
  id             String   @id @default(cuid())
  companyId      String
  url            String
  /// Shared secret for HMAC-SHA256 of raw JSON body (`X-HGH-Signature: sha256=<hex>`)
  secret         String
  payrunApproved Boolean  @default(true)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

/// Staff checklist on employee profile (onboarding / probation tasks)
model EmployeeOnboardingTask {
  id          String    @id @default(cuid())
  employeeId  String
  title       String
  description String?
  sortOrder   Int       @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

/// Employee requests a fix to a check-in record; HR/admin approves and times update
model AttendanceCorrectionRequest {
  id                String                     @id @default(cuid())
  checkInId         String
  employeeId        String
  companyId         String
  requestedByUserId String
  reason            String
  proposedClockIn   DateTime?
  proposedClockOut  DateTime?
  status            AttendanceCorrectionStatus @default(PENDING)
  reviewedById      String?
  reviewedAt        DateTime?
  reviewNote        String?
  createdAt         DateTime                   @default(now())

  checkIn     CheckIn  @relation(fields: [checkInId], references: [id], onDelete: Cascade)
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requestedBy User     @relation("CorrectionRequestedBy", fields: [requestedByUserId], references: [id])
  reviewedBy  User?    @relation("CorrectionReviewedBy", fields: [reviewedById], references: [id])

  @@index([companyId, status])
  @@index([employeeId])
}

// ─── Onboarding Tracker (Section 2) ──────────────────────────────────────────

enum OnboardingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

enum OnboardingTaskStatus {
  PENDING
  COMPLETED
  OVERDUE
  WAIVED
}

model OnboardingTemplate {
  id        String   @id @default(cuid())
  tenantId  String
  companyId String
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks       OnboardingTemplateTask[]
  onboardings EmployeeOnboarding[]

  @@index([companyId])
}

model OnboardingTemplateTask {
  id           String  @id @default(cuid())
  templateId   String
  title        String
  description  String?
  dueAfterDays Int
  isRequired   Boolean @default(true)
  order        Int     @default(0)

  template OnboardingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

model EmployeeOnboarding {
  id          String           @id @default(cuid())
  employeeId  String
  tenantId    String
  companyId   String
  templateId  String
  startDate   DateTime
  completedAt DateTime?
  status      OnboardingStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  employee Employee                  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  template OnboardingTemplate        @relation(fields: [templateId], references: [id])
  tasks    OnboardingChecklistItem[]

  @@index([companyId])
  @@index([employeeId])
}

model OnboardingChecklistItem {
  id             String               @id @default(cuid())
  onboardingId   String
  templateTaskId String?
  title          String
  dueDate        DateTime
  isRequired     Boolean              @default(true)
  status         OnboardingTaskStatus @default(PENDING)
  completedAt    DateTime?
  completedBy    String?
  waivedBy       String?
  waivedNote     String?

  onboarding EmployeeOnboarding @relation(fields: [onboardingId], references: [id], onDelete: Cascade)

  @@index([onboardingId])
}

// ─── Performance Management (Section 3) ──────────────────────────────────────

enum PerformanceCycleStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum PerformanceReviewStatus {
  PENDING
  SELF_REVIEWED
  MANAGER_REVIEWED
  COMPLETED
}

model PerformanceCycle {
  id          String                 @id @default(cuid())
  tenantId    String
  companyId   String
  name        String
  periodStart DateTime
  periodEnd   DateTime
  status      PerformanceCycleStatus @default(DRAFT)
  createdAt   DateTime               @default(now())

  reviews PerformanceReview[]

  @@index([companyId, status])
}

model PerformanceReview {
  id             String                  @id @default(cuid())
  cycleId        String
  employeeId     String
  reviewerId     String?
  status         PerformanceReviewStatus @default(PENDING)
  selfRating     Float?
  managerRating  Float?
  finalRating    Float?
  selfComment    String?
  managerComment String?
  submittedAt    DateTime?
  completedAt    DateTime?

  cycle    PerformanceCycle  @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  employee Employee          @relation(fields: [employeeId], references: [id])
  goals    PerformanceGoal[]

  @@index([cycleId])
  @@index([employeeId])
}

model PerformanceGoal {
  id           String  @id @default(cuid())
  reviewId     String
  title        String
  description  String?
  selfScore    Int?
  managerScore Int?
  weight       Int

  review PerformanceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
}

// ─── Exit Management (Section 5) ─────────────────────────────────────────────

enum ExitType {
  RESIGNATION
  TERMINATION
  REDUNDANCY
  RETIREMENT
  CONTRACT_END
  DEATH
}

enum ExitStatus {
  INITIATED
  IN_PROGRESS
  CLEARED
  COMPLETED
}

enum ExitClearanceDepartment {
  IT
  FINANCE
  ADMIN
  MANAGER
  SECURITY
  OTHER
}

enum ExitClearanceStatus {
  PENDING
  CLEARED
  WAIVED
}

model ExitRecord {
  id                String     @id @default(cuid())
  employeeId        String
  tenantId          String
  companyId         String
  exitType          ExitType
  noticeDate        DateTime
  lastWorkingDay    DateTime
  exitInterviewDate DateTime?
  reason            String?
  status            ExitStatus @default(INITIATED)
  finalPayrunId     String?
  createdBy         String
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  employee       Employee            @relation(fields: [employeeId], references: [id])
  clearanceItems ExitClearanceItem[]

  @@index([companyId, status])
  @@index([employeeId])
}

model ExitClearanceItem {
  id           String                  @id @default(cuid())
  exitRecordId String
  department   ExitClearanceDepartment
  item         String
  assignedTo   String?
  status       ExitClearanceStatus     @default(PENDING)
  clearedAt    DateTime?
  clearedBy    String?
  note         String?

  exitRecord ExitRecord @relation(fields: [exitRecordId], references: [id], onDelete: Cascade)

  @@index([exitRecordId])
}

// ─── Revenue Tracker (Section 8) ─────────────────────────────────────────────

model RevenueEntry {
  id            String   @id @default(cuid())
  tenantId      String
  companyId     String
  month         Int
  year          Int
  revenueAmount Decimal  @db.Decimal(14, 2)
  note          String?
  enteredBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([companyId, month, year])
  @@index([companyId])
}
