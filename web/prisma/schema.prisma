// HGH Payroll — PostgreSQL on Supabase (pooled DATABASE_URL + DIRECT_URL for migrations)
// See: https://supabase.com/docs/guides/database/connecting-to-postgres
//
// DATABASE_URL (Transaction pooler / port 6543) MUST include ?pgbouncer=true (or &pgbouncer=true).
// Without it, Postgres can error: 42P05 "prepared statement \"sN\" already exists" on Vercel/PgBouncer.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  HR
  EMPLOYEE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACTOR
}

enum EmployeeStatus {
  ACTIVE
  SUSPENDED
  TERMINATED
}

enum SalaryComponentType {
  ALLOWANCE
  DEDUCTION
}

enum PayrunStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum LeaveType {
  ANNUAL
  SICK
  MATERNITY
  PATERNITY
  COMPASSIONATE
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LoanType {
  LOAN
  ADVANCE
}

enum LoanStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum SubscriptionStatus {
  NONE
  ACTIVE
  TRIAL
  PAST_DUE
  CANCELED
}

model Company {
  id                 String             @id @default(cuid())
  name               String
  logoUrl            String?
  registrationNumber String?
  address            String?
  isActive           Boolean            @default(true)
  /// ACTIVE = paid subscriber (full access). Other values: access until trialEndsAt (or createdAt + trial window if trialEndsAt is null).
  subscriptionStatus SubscriptionStatus @default(NONE)
  /// End of the free trial (all features). If null, the app treats the trial end as createdAt + 3 days (see TRIAL_DAYS in billing/access.ts).
  trialEndsAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  users             User[]
  employees         Employee[]
  payruns           Payrun[]
  taxBrackets       TaxBracket[]
  leaveEntitlements LeaveEntitlement[]
  invitations       Invitation[]

  /// Enterprise check-in (audit sessions)
  checkinEnterpriseEnabled Boolean @default(false)

  /// Office kiosk: local HH:mm in kioskTimezone (null = no open/close restriction)
  kioskOfficeOpensAt     String?
  kioskOfficeClosesAt    String?
  /// After this local time, new clock-in blocked; cron marks absent (shift employees)
  kioskCutoffTime        String?
  /// IANA timezone e.g. Africa/Accra
  kioskTimezone          String  @default("Africa/Accra")
  /// Local YYYY-MM-DD when kiosk absence cron last ran (idempotency)
  kioskLastAbsentRunDate String?

  /// Ghana Tier 2 occupational pension (optional); % of basic salary — employee deduction + employer cost on pay run lines
  tier2PensionEnabled  Boolean @default(false)
  tier2EmployeePercent Decimal @default(5) @db.Decimal(5, 2)
  tier2EmployerPercent Decimal @default(5) @db.Decimal(5, 2)

  /// Dashboard: upcoming birthdays / anniversaries widget
  showBirthdaysOnDashboard Boolean @default(true)
  birthdayLookaheadDays    Int       @default(30)

  /// Payslip PDF branding (react-pdf)
  payslipPrimaryHex       String @default("#0f172a")
  payslipAccentHex        String @default("#b45309")
  /// DEFAULT | MINIMAL | STRIPED
  payslipThemeVariant     String @default("DEFAULT")

  /// Overtime pay = sum(overtime hours in period) × implied hourly rate × multiplier
  overtimeHourlyMultiplier           Decimal @default(1.5) @db.Decimal(5, 2)
  standardHoursPerMonth              Decimal @default(173) @db.Decimal(6, 2)
  includeAttendanceOvertimeInPayrun  Boolean @default(true)

  kioskDayAbsences      KioskDayAbsence[]
  checkinSessions       CheckinSession[]
  kioskChallenges       KioskChallenge[]
  webhooks              CompanyWebhook[]
  attendanceCorrections AttendanceCorrectionRequest[]
  pinResetRequests      PinResetRequest[]
  publicHolidays        PublicHoliday[]
  latenessPolicy        LatenessPolicy?
  lateRecords           LateRecord[]
  payQueries            PayQuery[]
  anonymousFeedbacks    AnonymousFeedback[]
  companyNotices        CompanyNotice[]
  profileChangeRequests ProfileChangeRequest[]

  @@index([isActive])
}

model User {
  id         String   @id @default(cuid())
  /// Supabase Auth user id (`auth.users.id`)
  authUserId String   @unique
  email      String   @unique
  name       String
  role       UserRole
  isActive   Boolean  @default(true)
  companyId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company                        Company?                      @relation(fields: [companyId], references: [id])
  employee                       Employee?
  /// Employees who report to this dashboard user (leave/inbox "my team").
  managedEmployees               Employee[]                    @relation("EmployeeManager")
  auditLogs                      AuditLog[]
  invitations                    Invitation[]
  attendanceCorrectionsRequested AttendanceCorrectionRequest[] @relation("CorrectionRequestedBy")
  attendanceCorrectionsReviewed  AttendanceCorrectionRequest[] @relation("CorrectionReviewedBy")
  companyNoticesAuthored         CompanyNotice[]                 @relation("NoticeAuthor")
  payQueriesAnswered             PayQuery[]                      @relation("PayQueryResponder")
  profileChangeReviews           ProfileChangeRequest[]          @relation("ProfileChangeReviewer")
  anonymousFeedbackReviewed      AnonymousFeedback[]             @relation("AnonymousFeedbackReviewer")

  @@index([authUserId])
  @@index([companyId, role])
}

model Employee {
  id                   String         @id @default(cuid())
  employeeCode         String         @unique
  /// Display name on the HR record (independent of linked User.name when invited)
  name                 String?
  userId               String?        @unique
  companyId            String
  department           String
  jobTitle             String
  employmentType       EmploymentType @default(FULL_TIME)
  startDate            DateTime
  status               EmployeeStatus @default(ACTIVE)
  basicSalary          Decimal        @db.Decimal(12, 2)
  ssnitEncrypted       String?
  tinEncrypted         String?
  bankNameEncrypted    String?
  bankAccountEncrypted String?
  bankBranchEncrypted  String?
  /// MTN_MOMO | TELECEL_CASH | AT_MONEY — Ghana mobile money salary rail (optional).
  momoProvider         String?
  momoMsisdnEncrypted  String?
  nokName              String?
  nokPhone             String?
  nokRelationship      String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  deletedAt            DateTime?

  /// SHA-256 hash of the device token bound to this employee for kiosk check-in
  kioskDeviceTokenHash String?
  /// When the device was first bound
  deviceBoundAt        DateTime?
  /// When the device binding was last reset by HR/admin
  deviceResetAt        DateTime?
  /// User ID of the admin who last reset the device binding
  deviceResetBy        String?

  /// Employee self-service (PIN auth, separate from Supabase)
  portalPin            String?
  temporaryPin         String?
  pinChangedAt         DateTime?
  portalLastLoginAt    DateTime?
  portalEnabled        Boolean   @default(true)
  portalFailedAttempts Int       @default(0)
  portalLockedUntil    DateTime?

  dateOfBirth       DateTime?
  probationEndDate  DateTime?
  contractType      String?
  contractStartDate DateTime?
  contractEndDate   DateTime?

  company                      Company                       @relation(fields: [companyId], references: [id])
  user                         User?                         @relation(fields: [userId], references: [id])
  managedByUserId              String?
  managedBy                    User?                         @relation("EmployeeManager", fields: [managedByUserId], references: [id])
  salaryComponents             SalaryComponent[]
  payrunLines                  PayrunLine[]
  payslips                     Payslip[]
  leaveRequests                LeaveRequest[]
  loans                        Loan[]
  checkIns                     CheckIn[]
  shiftAssignments             ShiftAssignment[]
  documents                    EmployeeDocument[]
  checkinSessions              CheckinSession[]
  kioskChallenges              KioskChallenge[]
  kioskDayAbsences             KioskDayAbsence[]
  onboardingTasks              EmployeeOnboardingTask[]
  attendanceCorrectionRequests AttendanceCorrectionRequest[]
  employeeOnboardings          EmployeeOnboarding[]
  performanceReviews           PerformanceReview[]
  exitRecords                  ExitRecord[]
  portalNotifications          PortalNotification[]
  pinResetRequests             PinResetRequest[]
  payQueries                   PayQuery[]
  profileChangeRequests       ProfileChangeRequest[]
  lateRecords                  LateRecord[]
  noticeReceipts               NoticeReceipt[]

  @@index([companyId, status])
  @@index([employeeCode])
  @@index([kioskDeviceTokenHash])
}

enum PortalNotificationType {
  PAYSLIP_PUBLISHED
  LEAVE_APPROVED
  LEAVE_REJECTED
  LOAN_APPROVED
  LOAN_REJECTED
  QUERY_RESPONDED
  SHIFT_SWAP_APPROVED
  SHIFT_SWAP_REJECTED
  ONBOARDING_TASK_DUE
  PERFORMANCE_REVIEW_OPEN
  DOCUMENT_REQUIRED
  PIN_RESET
  COMPANY_NOTICE
  PAY_QUERY_UPDATE
  PROFILE_REQUEST_DECIDED
  GENERAL
}

model PortalNotification {
  id         String                 @id @default(cuid())
  employeeId String
  tenantId   String
  type       PortalNotificationType
  title      String
  message    String
  linkUrl    String?
  isRead     Boolean                @default(false)
  createdAt  DateTime               @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, isRead])
  @@index([tenantId, createdAt])
}

enum PinResetRequestStatus {
  PENDING
  RESOLVED
  CANCELLED
}

model PinResetRequest {
  id         String                @id @default(cuid())
  employeeId String
  companyId  String
  status     PinResetRequestStatus @default(PENDING)
  otpHash    String?
  otpExpiresAt DateTime?
  createdAt  DateTime              @default(now())
  resolvedAt DateTime?
  adminNote  String?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([employeeId])
}

model EmployeeDocument {
  id         String   @id @default(cuid())
  employeeId String
  name       String
  fileUrl    String
  fileType   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
}

model SalaryComponent {
  id          String              @id @default(cuid())
  employeeId  String
  type        SalaryComponentType
  name        String
  amount      Decimal             @db.Decimal(12, 2)
  isRecurring Boolean             @default(true)
  startDate   DateTime            @default(now())
  endDate     DateTime?
  note        String?
  createdAt   DateTime            @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId, type])
}

model Payrun {
  id               String       @id @default(cuid())
  companyId        String
  periodStart      DateTime
  periodEnd        DateTime
  status           PayrunStatus @default(DRAFT)
  note             String?
  createdById      String
  submittedById    String?
  approvedById     String?
  rejectedById     String?
  rejectionNote    String?
  approvalNote     String?
  approvedAt       DateTime?
  lockedAt         DateTime?
  /// Payment tracking (Section 6)
  isPaid           Boolean      @default(false)
  paidAt           DateTime?
  scheduledPayDate DateTime?
  markedPaidBy     String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  company Company      @relation(fields: [companyId], references: [id])
  lines   PayrunLine[]

  @@index([companyId, status])
  @@index([periodStart, periodEnd])
}

model PayrunLine {
  id              String  @id @default(cuid())
  payrunId        String
  employeeId      String
  grossPay        Decimal @db.Decimal(12, 2)
  ssnitEmployee   Decimal @db.Decimal(12, 2)
  ssnitEmployer   Decimal @db.Decimal(12, 2)
  taxablePay      Decimal @db.Decimal(12, 2)
  payeTax         Decimal @db.Decimal(12, 2)
  provident       Decimal @default(0) @db.Decimal(12, 2)
  loanDeductions  Decimal @default(0) @db.Decimal(12, 2)
  otherDeductions Decimal @default(0) @db.Decimal(12, 2)
  tier2Employee   Decimal @default(0) @db.Decimal(12, 2)
  tier2Employer   Decimal @default(0) @db.Decimal(12, 2)
  totalDeductions Decimal @db.Decimal(12, 2)
  netPay          Decimal @db.Decimal(12, 2)
  isOverridden    Boolean @default(false)
  overrideNote    String?
  salarySnapshot  Json

  payrun   Payrun   @relation(fields: [payrunId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])
  payslip  Payslip?

  @@unique([payrunId, employeeId])
  @@index([payrunId])
}

model Payslip {
  id            String    @id @default(cuid())
  payrunLineId  String    @unique
  employeeId    String
  pdfUrl        String
  emailedAt     DateTime?
  downloadCount Int       @default(0)
  createdAt     DateTime  @default(now())

  payrunLine PayrunLine @relation(fields: [payrunLineId], references: [id])
  employee   Employee   @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
}

model LeaveEntitlement {
  id                 String    @id @default(cuid())
  companyId          String
  leaveType          LeaveType
  /// Base annual (or period) entitlement in days
  days               Int
  isActive           Boolean   @default(true)
  /// Optional: extra days accrued per calendar month employed (from startDate), added to entitled cap
  monthlyAccrualRate Decimal?  @db.Decimal(5, 2)
  /// Optional: ceiling on total entitled (base + accrual); null = no cap
  maxBalanceDays     Int?

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, leaveType])
}

model LeaveRequest {
  id            String      @id @default(cuid())
  employeeId    String
  type          LeaveType
  startDate     DateTime
  endDate       DateTime
  days          Int
  status        LeaveStatus @default(PENDING)
  note          String?
  approvedById  String?
  approvedAt    DateTime?
  rejectionNote String?
  approvalNote  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId, status])
  @@index([startDate, endDate])
}

model Loan {
  id               String     @id @default(cuid())
  employeeId       String
  type             LoanType
  amount           Decimal    @db.Decimal(12, 2)
  balance          Decimal    @db.Decimal(12, 2)
  monthlyRepayment Decimal    @db.Decimal(12, 2)
  disbursedAt      DateTime
  status           LoanStatus @default(ACTIVE)
  note             String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId, status])
}

model TaxBracket {
  id        String   @id @default(cuid())
  companyId String?
  year      Int
  minAmount Decimal  @db.Decimal(12, 2)
  maxAmount Decimal? @db.Decimal(12, 2)
  rate      Decimal  @db.Decimal(5, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id])

  @@index([year, isActive])
}

// ─── Check-in & Shift Enums ─────────────────────────────────────────────────

enum CheckInStatus {
  CLOCKED_IN
  CLOCKED_OUT
}

enum CheckinSessionEventType {
  PORTAL_OPENED
  CLOCK_IN
  CLOCK_OUT
  SESSION_INTERRUPTED
  TAB_HIDDEN
  TAB_VISIBLE
}

enum ShiftStatus {
  ACTIVE
  INACTIVE
}

// ─── Check-in & Shift Models ────────────────────────────────────────────────

model CheckIn {
  id                 String        @id @default(cuid())
  employeeId         String
  companyId          String
  clockIn            DateTime      @default(now())
  clockOut           DateTime?
  status             CheckInStatus @default(CLOCKED_IN)
  /// Total hours worked (computed on clock-out)
  hoursWorked        Decimal?      @db.Decimal(6, 2)
  /// Overtime hours beyond scheduled shift (computed on clock-out)
  overtimeHours      Decimal?      @db.Decimal(6, 2)
  /// Minutes late relative to shift start
  lateMinutes        Int?
  /// Minutes early departure relative to shift end
  earlyDepartMinutes Int?
  note               String?
  /// If linked to a shift assignment
  shiftAssignmentId  String?
  /// Enterprise check-in session (audit trail)
  checkinSessionId   String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  employee           Employee                      @relation(fields: [employeeId], references: [id])
  shiftAssignment    ShiftAssignment?              @relation(fields: [shiftAssignmentId], references: [id])
  checkinSession     CheckinSession?               @relation(fields: [checkinSessionId], references: [id])
  correctionRequests AttendanceCorrectionRequest[]
  lateRecords        LateRecord[]

  @@index([employeeId, clockIn])
  @@index([companyId, clockIn])
  @@index([companyId, status])
  @@index([checkinSessionId])
}

model CheckinSession {
  id         String    @id @default(cuid())
  employeeId String
  companyId  String
  clientIp   String?
  userAgent  String?
  endedAt    DateTime?
  createdAt  DateTime  @default(now())

  employee Employee       @relation(fields: [employeeId], references: [id])
  company  Company        @relation(fields: [companyId], references: [id])
  events   CheckinEvent[]
  checkIns CheckIn[]

  @@index([employeeId, createdAt])
  @@index([companyId, createdAt])
}

model CheckinEvent {
  id        String                  @id @default(cuid())
  sessionId String
  type      CheckinSessionEventType
  metadata  Json?
  createdAt DateTime                @default(now())

  session CheckinSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

/// Local calendar day in company kioskTimezone; absence if no check-in by cutoff.
model KioskDayAbsence {
  id         String   @id @default(cuid())
  companyId  String
  employeeId String
  /// Local date YYYY-MM-DD for company timezone
  localDate  String
  reason     String   @default("MISSING_CHECKIN")
  createdAt  DateTime @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([companyId, employeeId, localDate])
  @@index([companyId, localDate])
}

model Shift {
  id           String      @id @default(cuid())
  companyId    String
  name         String /// e.g. "Morning", "Afternoon", "Night"
  startTime    String /// HH:mm format, e.g. "08:00"
  endTime      String /// HH:mm format, e.g. "17:00"
  breakMinutes Int         @default(60)
  status       ShiftStatus @default(ACTIVE)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  assignments ShiftAssignment[]

  @@index([companyId, status])
}

model ShiftAssignment {
  id         String    @id @default(cuid())
  shiftId    String
  employeeId String
  /// Effective date range for this assignment
  startDate  DateTime
  endDate    DateTime?
  createdAt  DateTime  @default(now())

  shift    Shift     @relation(fields: [shiftId], references: [id])
  employee Employee  @relation(fields: [employeeId], references: [id])
  checkIns CheckIn[]

  @@index([employeeId, startDate])
  @@index([shiftId])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

model Invitation {
  id        String           @id @default(cuid())
  email     String
  role      UserRole
  companyId String
  code      String           @unique
  status    InvitationStatus @default(PENDING)
  invitedBy String
  expiresAt DateTime
  createdAt DateTime         @default(now())

  company Company @relation(fields: [companyId], references: [id])
  inviter User    @relation(fields: [invitedBy], references: [id])

  @@index([email, status])
  @@index([code])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String
  action      String
  entityType  String
  entityId    String
  beforeState Json?
  afterState  Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

enum AttendanceCorrectionStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Outbound integration (e.g. Zapier / internal tools) — fired when a pay run is approved
model CompanyWebhook {
  id             String   @id @default(cuid())
  companyId      String
  url            String
  /// Shared secret for HMAC-SHA256 of raw JSON body (`X-HGH-Signature: sha256=<hex>`)
  secret         String
  payrunApproved Boolean  @default(true)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

/// Staff checklist on employee profile (onboarding / probation tasks)
model EmployeeOnboardingTask {
  id          String    @id @default(cuid())
  employeeId  String
  title       String
  description String?
  sortOrder   Int       @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

/// Employee requests a fix to a check-in record; HR/admin approves and times update
model AttendanceCorrectionRequest {
  id                String                     @id @default(cuid())
  checkInId         String
  employeeId        String
  companyId         String
  /// Null when submitted from employee PIN portal (no linked User).
  requestedByUserId String?
  reason            String
  proposedClockIn   DateTime?
  proposedClockOut  DateTime?
  status            AttendanceCorrectionStatus @default(PENDING)
  reviewedById      String?
  reviewedAt        DateTime?
  reviewNote        String?
  createdAt         DateTime                   @default(now())

  checkIn     CheckIn  @relation(fields: [checkInId], references: [id], onDelete: Cascade)
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requestedBy User?    @relation("CorrectionRequestedBy", fields: [requestedByUserId], references: [id])
  reviewedBy  User?    @relation("CorrectionReviewedBy", fields: [reviewedById], references: [id])

  @@index([companyId, status])
  @@index([employeeId])
}

// ─── Onboarding Tracker (Section 2) ──────────────────────────────────────────

enum OnboardingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

enum OnboardingTaskStatus {
  PENDING
  COMPLETED
  OVERDUE
  WAIVED
}

model OnboardingTemplate {
  id        String   @id @default(cuid())
  tenantId  String
  companyId String
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks       OnboardingTemplateTask[]
  onboardings EmployeeOnboarding[]

  @@index([companyId])
}

model OnboardingTemplateTask {
  id           String  @id @default(cuid())
  templateId   String
  title        String
  description  String?
  dueAfterDays Int
  isRequired   Boolean @default(true)
  order        Int     @default(0)

  template OnboardingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

model EmployeeOnboarding {
  id          String           @id @default(cuid())
  employeeId  String
  tenantId    String
  companyId   String
  templateId  String
  startDate   DateTime
  completedAt DateTime?
  status      OnboardingStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  employee Employee                  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  template OnboardingTemplate        @relation(fields: [templateId], references: [id])
  tasks    OnboardingChecklistItem[]

  @@index([companyId])
  @@index([employeeId])
}

model OnboardingChecklistItem {
  id             String               @id @default(cuid())
  onboardingId   String
  templateTaskId String?
  title          String
  dueDate        DateTime
  isRequired     Boolean              @default(true)
  status         OnboardingTaskStatus @default(PENDING)
  completedAt    DateTime?
  completedBy    String?
  waivedBy       String?
  waivedNote     String?

  onboarding EmployeeOnboarding @relation(fields: [onboardingId], references: [id], onDelete: Cascade)

  @@index([onboardingId])
}

// ─── Performance Management (Section 3) ──────────────────────────────────────

enum PerformanceCycleStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum PerformanceReviewStatus {
  PENDING
  SELF_REVIEWED
  MANAGER_REVIEWED
  COMPLETED
}

model PerformanceCycle {
  id          String                 @id @default(cuid())
  tenantId    String
  companyId   String
  name        String
  periodStart DateTime
  periodEnd   DateTime
  status      PerformanceCycleStatus @default(DRAFT)
  createdAt   DateTime               @default(now())

  reviews PerformanceReview[]

  @@index([companyId, status])
}

model PerformanceReview {
  id             String                  @id @default(cuid())
  cycleId        String
  employeeId     String
  reviewerId     String?
  status         PerformanceReviewStatus @default(PENDING)
  selfRating     Float?
  managerRating  Float?
  finalRating    Float?
  selfComment    String?
  managerComment String?
  submittedAt    DateTime?
  completedAt    DateTime?

  cycle    PerformanceCycle  @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  employee Employee          @relation(fields: [employeeId], references: [id])
  goals    PerformanceGoal[]

  @@index([cycleId])
  @@index([employeeId])
}

model PerformanceGoal {
  id           String  @id @default(cuid())
  reviewId     String
  title        String
  description  String?
  selfScore    Int?
  managerScore Int?
  weight       Int

  review PerformanceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
}

// ─── Exit Management (Section 5) ─────────────────────────────────────────────

enum ExitType {
  RESIGNATION
  TERMINATION
  REDUNDANCY
  RETIREMENT
  CONTRACT_END
  DEATH
}

enum ExitStatus {
  INITIATED
  IN_PROGRESS
  CLEARED
  COMPLETED
}

enum ExitClearanceDepartment {
  IT
  FINANCE
  ADMIN
  MANAGER
  SECURITY
  OTHER
}

enum ExitClearanceStatus {
  PENDING
  CLEARED
  WAIVED
}

model ExitRecord {
  id                String     @id @default(cuid())
  employeeId        String
  tenantId          String
  companyId         String
  exitType          ExitType
  noticeDate        DateTime
  lastWorkingDay    DateTime
  exitInterviewDate DateTime?
  reason            String?
  status            ExitStatus @default(INITIATED)
  finalPayrunId     String?
  createdBy         String
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  employee       Employee            @relation(fields: [employeeId], references: [id])
  clearanceItems ExitClearanceItem[]

  @@index([companyId, status])
  @@index([employeeId])
}

model ExitClearanceItem {
  id           String                  @id @default(cuid())
  exitRecordId String
  department   ExitClearanceDepartment
  item         String
  assignedTo   String?
  status       ExitClearanceStatus     @default(PENDING)
  clearedAt    DateTime?
  clearedBy    String?
  note         String?

  exitRecord ExitRecord @relation(fields: [exitRecordId], references: [id], onDelete: Cascade)

  @@index([exitRecordId])
}

// ─── Kiosk QR Challenge-Response ─────────────────────────────────────────────

model KioskChallenge {
  id             String   @id @default(cuid())
  companyId      String
  employeeId     String
  /// 6-digit verification code shown on the employee's phone
  code           String
  /// Whether the device verification step passed
  deviceVerified Boolean  @default(false)
  /// Whether this challenge has been consumed (code entered on kiosk)
  consumed       Boolean  @default(false)
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  company  Company  @relation(fields: [companyId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([companyId])
  @@index([employeeId])
  @@index([expiresAt])
}

// ─── Revenue Tracker (Section 8) ─────────────────────────────────────────────

model RevenueEntry {
  id            String   @id @default(cuid())
  tenantId      String
  companyId     String
  month         Int
  year          Int
  revenueAmount Decimal  @db.Decimal(14, 2)
  note          String?
  enteredBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([companyId, month, year])
  @@index([companyId])
}

// ─── Workplace / HR extensions (roadmap Feature 1–12) ────────────────────────

enum PayQueryStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum AnonymousFeedbackStatus {
  NEW
  REVIEWED
  ARCHIVED
}

enum ProfileChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CompanyNoticeStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model PublicHoliday {
  id        String   @id @default(cuid())
  companyId String
  date      DateTime
  name      String
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, date])
  @@index([companyId])
}

model LatenessPolicy {
  id                         String  @id @default(cuid())
  companyId                  String  @unique
  graceMinutes               Int     @default(5)
  lateInstancesBeforeWarning Int?
  warningLetterBodyTemplate  String? @db.Text

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model LateRecord {
  id                  String    @id @default(cuid())
  companyId           String
  employeeId          String
  checkInId           String?
  date                DateTime
  minutesLate         Int
  warningLetterSentAt DateTime?
  notes               String?
  createdAt           DateTime  @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  checkIn  CheckIn? @relation(fields: [checkInId], references: [id], onDelete: SetNull)

  @@index([companyId, date])
  @@index([employeeId])
}

model PayQuery {
  id            String         @id @default(cuid())
  companyId     String
  employeeId    String
  subject       String
  body          String         @db.Text
  status        PayQueryStatus @default(OPEN)
  responseBody  String?        @db.Text
  respondedById String?
  respondedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  respondedBy User?    @relation("PayQueryResponder", fields: [respondedById], references: [id])

  @@index([companyId, status])
  @@index([employeeId])
}

model AnonymousFeedback {
  id           String                  @id @default(cuid())
  companyId    String
  message      String                  @db.Text
  category     String?
  status       AnonymousFeedbackStatus @default(NEW)
  reviewedById String?
  reviewedAt   DateTime?
  internalNote String?                 @db.Text
  createdAt    DateTime                @default(now())

  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reviewedBy User?   @relation("AnonymousFeedbackReviewer", fields: [reviewedById], references: [id])

  @@index([companyId, status])
}

model ProfileChangeRequest {
  id           String                     @id @default(cuid())
  companyId    String
  employeeId   String
  changesJson  Json
  employeeNote String?
  status       ProfileChangeRequestStatus @default(PENDING)
  reviewerNote String?
  decidedById  String?
  decidedAt    DateTime?
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee  Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  decidedBy User?    @relation("ProfileChangeReviewer", fields: [decidedById], references: [id])

  @@index([companyId, status])
  @@index([employeeId])
}

model CompanyNotice {
  id          String              @id @default(cuid())
  companyId   String
  title       String
  body        String              @db.Text
  status      CompanyNoticeStatus @default(PUBLISHED)
  publishedAt DateTime            @default(now())
  expiresAt   DateTime?
  createdById String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  company   Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy User            @relation("NoticeAuthor", fields: [createdById], references: [id])
  receipts  NoticeReceipt[]

  @@index([companyId, publishedAt])
}

model NoticeReceipt {
  id         String   @id @default(cuid())
  noticeId   String
  employeeId String
  readAt     DateTime @default(now())

  notice   CompanyNotice @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  employee Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([noticeId, employeeId])
  @@index([employeeId])
}
