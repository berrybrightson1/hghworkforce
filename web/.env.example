# ── Put secrets in `.env.local` in THIS folder (`web/`), not the parent repo root.
#    Next.js only loads env from `web/` where `next.config.ts` lives.
#    Restart `npm run dev` after changing env.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Billing (optional): plan limits apply only when BOTH are set — see web/lib/billing/enforcement.ts
# BILLING_ENFORCED=true
# STRIPE_SECRET_KEY=

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
#
# Auth: add these to Supabase → Authentication → URL configuration → Redirect URLs:
#   http://localhost:3000/auth/callback
#   https://YOUR_PRODUCTION_DOMAIN/auth/callback

# Server-only: admin scripts / webhooks (never expose to the browser)
# SUPABASE_SERVICE_ROLE_KEY=

# Supabase Postgres — Project Settings → Database (Prisma)
# Easiest for local dev: direct host (ref = subdomain of your-project.supabase.co, no AWS region):
#   postgresql://postgres:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
# Optional: copy "Transaction pooler" URI for DATABASE_URL (6543) and "Direct" for DIRECT_URL from the dashboard.
DATABASE_URL="postgresql://postgres:eaoDKdueNt0U3Cae@db.otqpuecirkdhgwvizpnf.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:eaoDKdueNt0U3Cae@db.otqpuecirkdhgwvizpnf.supabase.co:5432/postgres"
