# ── Put secrets in `.env.local` in THIS folder (`web/`), not the parent repo root.
#    Next.js loads `.env.local` for `npm run dev` / `next build`.
#
#    Prisma CLI (`db push`, `migrate`) loads `.env` in this folder, not `.env.local`.
#    Put DATABASE_URL + DIRECT_URL in `.env` as well, or export them in the shell.
#    Restart `npm run dev` after changing env.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Billing (optional): plan limits apply only when BOTH are set — see web/lib/billing/enforcement.ts
# BILLING_ENFORCED=true
# STRIPE_SECRET_KEY=

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
#
# Auth: add these to Supabase → Authentication → URL configuration → Redirect URLs:
#   http://localhost:3000/auth/callback
#   https://YOUR_PRODUCTION_DOMAIN/auth/callback

# Server-only: admin scripts / webhooks (never expose to the browser)
# SUPABASE_SERVICE_ROLE_KEY=

# Supabase Postgres — Dashboard → Project Settings → Database → Connection string
#
# prisma/schema.prisma uses `url` + `directUrl`. For Vercel/serverless you MUST NOT use the
# direct host (db.*.supabase.co:5432) as DATABASE_URL — connections from Lambda often time out.
#
# • DIRECT_URL (migrations / prisma CLI): "Direct connection", port 5432, host db.YOUR_REF.supabase.co
# • DATABASE_URL (runtime, including Vercel): "Transaction pooler", port 6543, append ?pgbouncer=true
#   Example pattern (copy the exact URI from Supabase; add query params if missing):
#   postgresql://postgres.YOUR_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
#
# Local dev can use 5432 direct for both if that works on your machine.
DATABASE_URL="postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

# Kiosk short-lived session HMAC (min 16 chars in production). Loaded by Next at runtime.
# KIOSK_SESSION_SECRET=

# Vercel Cron: Authorization: Bearer <CRON_SECRET> for /api/cron/kiosk-absences
# CRON_SECRET=

# Production / Vercel (also set in Vercel → Project → Settings → Environment Variables)
# NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
# ENCRYPTION_KEY=<output of: openssl rand -hex 32>  — required for real payroll data; do not use dev default
# BLOB_READ_WRITE_TOKEN=…  — Vercel Dashboard → Storage → Blob (employee Documents uploads)
# Optional API rate limits (middleware): UPSTASH_REDIS_REST_URL, UPSTASH_REDIS_REST_TOKEN
