# ── Copy to `.env.local` and fill with real values (never commit `.env.local`).
#    Next.js loads `.env.local` for `npm run dev` / `next build`.
#
#    Prisma CLI does NOT load `.env.local` by default. This repo runs migrations via:
#      npm run db:push   /   npm run db:migrate   (loads `.env.local` through dotenv-cli).
#    Both DATABASE_URL and DIRECT_URL must be set (Supabase: pooler :6543 + direct db.* :5432).
#    Or: create `web/.env` with those two lines and run `npx prisma db push` as usual.

# Public site URL (no trailing slash). Used for copied links (referrals, kiosk URL, etc.).
# Local dev: http://localhost:3000 — or your port if not 3000.
# Production: https://your-production-domain.com (same origin users use in the browser).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: override /subscribe card prices (JSON). Defaults: Payroll & Attendance ¢299/mo & ¢2,999/yr; Pro ¢499/mo & ¢4,999/yr.
# Example:
# NEXT_PUBLIC_PLAN_PRICES={"STARTER_PAYROLL":{"monthly":"¢299/mo","yearly":"¢2,999/yr"},"STARTER_ATTENDANCE":{"monthly":"¢299/mo","yearly":"¢2,999/yr"},"PRO":{"monthly":"¢499/mo","yearly":"¢4,999/yr"}}

# Billing — server-side only (never shown in the product UI). Paystack for Ghana is planned; until
# then optional legacy Stripe checkout uses:
# BILLING_ENFORCED=true
# STRIPE_SECRET_KEY=...
# STRIPE_PRICE_ID=...
# Used for correct checkout return URLs in production:
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Supabase — Project Settings → API (replace placeholders; anon key is safe in NEXT_PUBLIC_* with RLS)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Server-only — required for “workspace question” password change (auth admin API). Optional otherwise.
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Postgres — Project Settings → Database → Connection strings
# DATABASE_URL: Transaction pooler, port 6543 — MUST include pgbouncer for Prisma
# DIRECT_URL: Session/direct host db.*.supabase.co, port 5432 — for migrations
# Production (e.g. Vercel): use connection_limit=1 per instance. Local dev: use 5–10 (or omit
# connection_limit / pool_timeout so web/lib/prisma.ts can add dev-friendly defaults when flags are missing).
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Employee PIN portal — JWT for httpOnly cookie `hgh_portal_session` (separate from Supabase)
# Also used to sign signup precheck tickets if SIGNUP_TICKET_SECRET is unset.
# Generate: openssl rand -base64 32
# PORTAL_JWT_SECRET=

# Optional: separate secret for HMAC signup precheck tickets (defaults to PORTAL_JWT_SECRET)
# SIGNUP_TICKET_SECRET=

# Kiosk session HMAC (min 16 chars in production)
# KIOSK_SESSION_SECRET=

# Vercel Cron: Authorization: Bearer <CRON_SECRET> for /api/cron/kiosk-absences
# CRON_SECRET=

# Production — required (64 hex chars). Without this, creating/updating employees with tax or bank/MoMo data fails.
# Generate: openssl rand -hex 32   → add ENCRYPTION_KEY in Vercel (or your host) on all Production/Preview envs, redeploy.
# ENCRYPTION_KEY=<paste_64_hex_chars_here>
# BLOB_READ_WRITE_TOKEN=
# UPSTASH_REDIS_REST_URL= / UPSTASH_REDIS_REST_TOKEN=
